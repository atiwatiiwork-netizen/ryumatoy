# Supabase — copy to .env.local and fill in. Note the NEXT_PUBLIC_ prefix
# (Next.js convention) — these are exposed to the browser bundle, which is fine
# for the URL + anon key. When empty, the app runs on seed data (preview mode).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret for the LINE push API route (never prefixed NEXT_PUBLIC_).
LINE_CHANNEL_TOKEN=
